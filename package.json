{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite --port 3000",
    "perf:bundle-report": "npm run build && node ./scripts/report-bundle-sizes.mjs",
    "perf:smoke-note": "echo \"Record route-interaction timings from browser DevTools Performance for / and first fiber detail open\"",
    "perf:baseline": "npm run perf:bundle-report && npm run perf:smoke-note",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.health.json",
    "admin:verify:canonical": "vitest run src/app/routes.test.ts src/app/components/admin/admin-route-contract.test.ts && npm run typecheck && npm run build",
    "verify": "npm run test && npm run build",
    "audit": "npm audit --audit-level=high",
    "check:no-supabase": "node ./scripts/check-no-supabase.mjs",
    "ops:invalidate-cache": "node ./scripts/invalidate-upstash-cache.mjs",
    "ops:data-parity": "vitest run src/app/utils/admin/data-freshness-ci.test.ts && node ./scripts/data-freshness-api-parity.mjs",
    "ops:promote-diff": "node ./scripts/promote-atlas-diff.mjs",
    "ops:data-recovery": "node ./scripts/data-freshness-recovery.mjs",
    "ci:verify": "npm run typecheck && npm run test && npm run build && npm run audit && npm run check:no-supabase"
  },
